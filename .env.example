# ==============================================================================
# Hasir Deployment Environment Variables Example
# Copy this file to .env and fill in the values before deploying.
# ==============================================================================

# ------------------------------------------------------------------------------
# Domain and Deployment Configuration
# ------------------------------------------------------------------------------
# The domain name where Hasir will be hosted (e.g. hasir.example.com)
DOMAIN=example.com

# Email address for Let's Encrypt certificate registration and notifications
LETSENCRYPT_EMAIL=admin@example.com

# ------------------------------------------------------------------------------
# Image Tags (Defaults to latest if not specified)
# ------------------------------------------------------------------------------
API_TAG=latest
DASHBOARD_TAG=latest

# ------------------------------------------------------------------------------
# Database (PostgreSQL) Configuration
# ------------------------------------------------------------------------------
POSTGRES_USER=hasir
# <generate> Generate a secure random password (e.g. openssl rand -hex 24)
POSTGRES_PASSWORD=secure_random_postgres_password_here
POSTGRES_DB=hasir

# ------------------------------------------------------------------------------
# Security Configuration
# ------------------------------------------------------------------------------
# <generate> Secret key for JWT signing (e.g. openssl rand -hex 32)
JWT_SECRET=secure_random_jwt_secret_here

# ------------------------------------------------------------------------------
# SMTP (Email) Configuration
# ------------------------------------------------------------------------------
SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
SMTP_USERNAME=postmaster@example.com
SMTP_PASSWORD=smtp_password_here
SMTP_FROM=Hasir <noreply@example.com>
SMTP_USE_TLS=true
